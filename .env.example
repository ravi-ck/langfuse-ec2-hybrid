# Langfuse hybrid deployment — environment file
# Copy to `.env` and fill in every <PLACEHOLDER>. Never commit the real .env.
#
# Host services (Postgres/Redis/ClickHouse) are addressed as host.docker.internal.
# Blob storage uses real AWS S3.

# ----------------------------------------------------------------------------
# Secrets — CHANGE ALL OF THESE
# ----------------------------------------------------------------------------
# openssl rand -base64 32
NEXTAUTH_SECRET=<CHANGEME_base64_32>
# openssl rand -base64 32   (salt used to hash API keys)
SALT=<CHANGEME_base64_32>
# openssl rand -hex 32      (must be EXACTLY 64 hex characters)
ENCRYPTION_KEY=<CHANGEME_64_hex_chars>

# Public URL users hit (set to your HTTPS domain behind the reverse proxy)
NEXTAUTH_URL=https://langfuse.yourdomain.com

TELEMETRY_ENABLED=true
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES=false

# ----------------------------------------------------------------------------
# PostgreSQL (native on host)
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:<PG_PASSWORD>@host.docker.internal:5432/postgres

# ----------------------------------------------------------------------------
# Redis (native on host) — must run with maxmemory-policy noeviction
# ----------------------------------------------------------------------------
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_AUTH=<REDIS_PASSWORD>
REDIS_TLS_ENABLED=false

# ----------------------------------------------------------------------------
# ClickHouse (native on host) — single node, not clustered
# ----------------------------------------------------------------------------
CLICKHOUSE_URL=http://host.docker.internal:8123
CLICKHOUSE_MIGRATION_URL=clickhouse://host.docker.internal:9000
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=<CLICKHOUSE_PASSWORD>
CLICKHOUSE_CLUSTER_ENABLED=false

# ----------------------------------------------------------------------------
# AWS S3 — blob storage (event + media uploads)
# ----------------------------------------------------------------------------
# Credentials: leave the ACCESS_KEY/SECRET vars UNSET to use the EC2 instance
# IAM role (recommended). If you do that, set the instance metadata hop limit
# to 2 so containers can read IMDSv2 (see README). Otherwise uncomment and
# supply a dedicated IAM user's static keys.

# Event uploads (server-side only)
LANGFUSE_S3_EVENT_UPLOAD_BUCKET=<S3_BUCKET>
LANGFUSE_S3_EVENT_UPLOAD_REGION=<AWS_REGION>
LANGFUSE_S3_EVENT_UPLOAD_PREFIX=events/
LANGFUSE_S3_EVENT_UPLOAD_FORCE_PATH_STYLE=false
# LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=<AWS_ACCESS_KEY_ID>
# LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=<AWS_SECRET_ACCESS_KEY>

# Media uploads (browser fetches pre-signed URLs directly — real S3 works as-is)
LANGFUSE_S3_MEDIA_UPLOAD_BUCKET=<S3_BUCKET>
LANGFUSE_S3_MEDIA_UPLOAD_REGION=<AWS_REGION>
LANGFUSE_S3_MEDIA_UPLOAD_PREFIX=media/
LANGFUSE_S3_MEDIA_UPLOAD_FORCE_PATH_STYLE=false
# LANGFUSE_S3_MEDIA_UPLOAD_ACCESS_KEY_ID=<AWS_ACCESS_KEY_ID>
# LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=<AWS_SECRET_ACCESS_KEY>

LANGFUSE_ENABLE_BLOB_STORAGE_FILE_LOG=true

# Batch exports (optional; reuses the same bucket/role)
LANGFUSE_S3_BATCH_EXPORT_ENABLED=false
# LANGFUSE_S3_BATCH_EXPORT_BUCKET=<S3_BUCKET>
# LANGFUSE_S3_BATCH_EXPORT_REGION=<AWS_REGION>
# LANGFUSE_S3_BATCH_EXPORT_PREFIX=exports/

# ----------------------------------------------------------------------------
# Optional: SMTP for transactional email
# ----------------------------------------------------------------------------
# EMAIL_FROM_ADDRESS=
# SMTP_CONNECTION_URL=

# ----------------------------------------------------------------------------
# Optional: auto-provision an initial org/project/user on first boot
# ----------------------------------------------------------------------------
# LANGFUSE_INIT_ORG_ID=
# LANGFUSE_INIT_ORG_NAME=
# LANGFUSE_INIT_PROJECT_ID=
# LANGFUSE_INIT_PROJECT_NAME=
# LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
# LANGFUSE_INIT_PROJECT_SECRET_KEY=
# LANGFUSE_INIT_USER_EMAIL=
# LANGFUSE_INIT_USER_NAME=
# LANGFUSE_INIT_USER_PASSWORD=
